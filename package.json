{
    "name": "@quartinal/civil-database",
    "license": "GPL-3.0",
    "author": "Quartinal (Jasper Quartarolo)",
    "version": "0.0.3",
    "bin": {
        "civil2-db": "dist/civil2-db"
    },
    "exports": {
        "./client": {
            "import": "./dist/client/index.js",
            "types": "./dist/types/client/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "bun run scripts/build.ts",
        "start": "./dist/civil2-db",
        "dev": "bun --hot run src/run.ts",
        "format": "biome format --write",
        "lint": "biome lint --write"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.10",
        "@types/bun": "^1.3.11",
        "bun-plugin-dts": "^0.4.0",
        "graphql": "^16.13.2",
        "graphql-yoga": "^5.21.0",
        "ioredis": "^5.10.1",
        "postgres": "^3.4.8"
    }
}
